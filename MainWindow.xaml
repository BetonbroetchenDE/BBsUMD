<Window x:Class="BBs_Universal_Mod_Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BBs Universal Mod Downloader"
        Height="750"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        AllowsTransparency="True"
        MinWidth="3">

    <Window.Clip>
        <RectangleGeometry RadiusX="22" RadiusY="22" Rect="0,0,1000,750"/>
    </Window.Clip>

    <Window.Resources>
        <Color x:Key="Bg0">#0B0D10</Color>
        <Color x:Key="Bg1">#111318</Color>
        <Color x:Key="Bg2">#171A21</Color>
        <Color x:Key="Stroke">#242833</Color>
        <Color x:Key="StrokeSoft">#333847</Color>
        <Color x:Key="TextMain">#F2F5FA</Color>
        <Color x:Key="TextSub">#A7B0BE</Color>
        <Color x:Key="Accent">#66E3A1</Color>
        <Color x:Key="Accent2">#4CB3FF</Color>
        <Color x:Key="Danger">#FF6B6B</Color>

        <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0}" />
        <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}" />
        <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2}" />
        <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource Stroke}" />
        <SolidColorBrush x:Key="StrokeSoftBrush" Color="{StaticResource StrokeSoft}" />
        <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource TextMain}" />
        <SolidColorBrush x:Key="TextSubBrush" Color="{StaticResource TextSub}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />

        <SolidColorBrush x:Key="ButtonHoverBackground" Color="#273042"/>
        <SolidColorBrush x:Key="ButtonHoverBorder" Color="#3D4A62"/>
        <SolidColorBrush x:Key="ButtonPressedBackground" Color="#1B202B"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#202531" />
            <Setter Property="BorderBrush" Value="#30384A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <EventSetter Event="Click" Handler="Button_ClickSound"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.25"
                                                  Color="#000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource ButtonHoverBackground}" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ButtonHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource ButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#1E3A2C" />
            <Setter Property="BorderBrush" Value="#2A6B4D" />
            <Setter Property="Foreground" Value="#E9FFF2" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#3A1F22" />
            <Setter Property="BorderBrush" Value="#68343A" />
            <Setter Property="Foreground" Value="#FFECEC" />
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAB2C0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#262B36"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#141820"/>
            <Setter Property="BorderBrush" Value="#252B36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="22"
                BorderBrush="#262C39"
                BorderThickness="1"
                Background="{StaticResource Bg0Brush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.45"
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Border Margin="0"
                        CornerRadius="18"
                        Background="{StaticResource Bg1Brush}"
                        BorderBrush="#222835"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Top bar -->
                        <Border Grid.Row="0"
                                CornerRadius="18,18,0,0"
                                Background="#12151B"
                                BorderBrush="#202633"
                                BorderThickness="0,0,0,1"
                                MouseDown="TopBar_MouseDown">
                            <Grid Margin="18,0,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="LinkDot"
                                            Width="12"
                                            Height="12"
                                            CornerRadius="6"
                                            Background="{StaticResource AccentBrush}"
                                            Margin="0,0,12,0"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="Border_Click"/>

                                    <StackPanel>
                                        <TextBlock Text="BBs Universal Mod Downloader"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Click="Minimize_Click"
                                            Style="{StaticResource WindowButton}"
                                            Content="—"
                                            Margin="0,0,6,0"/>
                                    <Button Click="Exit_Click"
                                            Style="{StaticResource WindowButton}"
                                            Content="✕"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <Grid Grid.Row="1" Margin="28">
                            <!-- LOADING VIEW -->
                            <Grid x:Name="LoadingView" Opacity="1">
                                <Border Style="{StaticResource Card}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="420">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="76"
                                                Height="76"
                                                CornerRadius="38"
                                                Background="#18252A"
                                                BorderBrush="#22343A"
                                                BorderThickness="1"
                                                Margin="0,0,0,20">
                                            <Grid>
                                                <Ellipse Width="44"
                                                         Height="44"
                                                         Stroke="{StaticResource AccentBrush}"
                                                         StrokeThickness="4"
                                                         StrokeDashArray="2 4"
                                                         Opacity="0.95"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="Verbinde..."
                                                   Style="{StaticResource TitleText}"
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="Bitte warte, während die Verbindung aufgebaut wird."
                                                   Style="{StaticResource BodyText}"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,18"/>

                                        <ProgressBar Height="6"
                                                     IsIndeterminate="True"
                                                     Background="#1D2230"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,10"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ERROR VIEW -->
                            <Grid x:Name="ErrorView" Opacity="0" Visibility="Collapsed">
                                <Border Style="{StaticResource Card}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="470">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="74"
                                                Height="74"
                                                CornerRadius="37"
                                                Background="#2A171A"
                                                BorderBrush="#4C2329"
                                                BorderThickness="1"
                                                Margin="0,0,0,18">
                                            <TextBlock Text="✕"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="Fehler"
                                                   Foreground="{StaticResource DangerBrush}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock x:Name="ErrorMessageText"
                                                   Style="{StaticResource BodyText}"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Width="360"
                                                   Margin="0,0,0,18"/>

                                        <Button x:Name="CopyFullErrorButton"
                                                Content="Fehler kopieren"
                                                Click="CopyFullError_Click"
                                                Style="{StaticResource ModernButton}"
                                                MinWidth="220"
                                                Margin="0,0,0,12"/>

                                        <Button x:Name="ShowFullErrorButton"
                                                Content="Vollständigen Fehler anzeigen"
                                                Click="ShowFullError_Click"
                                                Style="{StaticResource ModernButton}"
                                                MinWidth="220"
                                                Margin="0,0,0,12"/>

                                        <Border x:Name="FullErrorPanel"
                                                Background="#10141B"
                                                BorderBrush="#222A36"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,18"
                                                Visibility="Collapsed"
                                                Width="400">
                                            <ScrollViewer MaxHeight="180"
                                                          VerticalScrollBarVisibility="Auto">
                                                <TextBox x:Name="FullErrorText"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="{StaticResource TextSubBrush}"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         IsHitTestVisible="False"/>
                                            </ScrollViewer>
                                        </Border>

                                        <Button Content="Erneut versuchen"
                                                Click="Retry_Click"
                                                Style="{StaticResource AccentButton}"
                                                MinWidth="160">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonHoverBackground" Color="#25523D"/>
                                                <SolidColorBrush x:Key="ButtonHoverBorder" Color="#2F7A5A"/>
                                                <SolidColorBrush x:Key="ButtonPressedBackground" Color="#18382B"/>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- MAIN VIEW -->
                            <Grid x:Name="MainView" Opacity="0" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                                    <TextBlock Text="Verbunden!"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="26"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*"/>
                                        <ColumnDefinition Width="0.85*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource Card}"
                                            Margin="0,0,14,0">
                                        <StackPanel>
                                            <TextBlock Text="Mod Downloader"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>

                                            <TextBlock Text="Wähle ein Spiel und öffne den Mod-Manager."
                                                       Style="{StaticResource BodyText}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,18"/>

                                            <Grid Margin="0,0,0,18">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="#10141B"
                                                        BorderBrush="#222A36"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="16"
                                                        Margin="0,0,8,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Status"
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   FontSize="11"/>
                                                        <TextBlock Text="Bereit"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Background="#10141B"
                                                        BorderBrush="#222A36"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="16"
                                                        Margin="8,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Ziel"
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   FontSize="11"/>
                                                        <TextBlock Text="Auto-Detect"
                                                                   Foreground="{StaticResource TextMainBrush}"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid>
                                                <!-- Game list -->
                                                <StackPanel x:Name="GameListView">
                                                    <Border x:Name="GameListContainer"
                                                            Background="#10141B"
                                                            BorderBrush="#222A36"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="10"
                                                            Margin="0,16,0,0">
                                                        <ScrollViewer MaxHeight="220"
                                                                      VerticalScrollBarVisibility="Auto">
                                                            <StackPanel x:Name="GameListPanel"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Game menu -->
                                                <Border x:Name="GameMenuView"
                                                        Background="#10141B"
                                                        BorderBrush="#222A36"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="16"
                                                        Margin="0,16,0,0"
                                                        Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock x:Name="SelectedGameTitle"
                                                                   Text="Spiel"
                                                                   Foreground="{StaticResource TextMainBrush}"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,4"/>

                                                        <TextBlock x:Name="SelectedGameInstallState"
                                                                   Text="(Nicht) Installiert"
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   FontSize="13"
                                                                   Margin="0,0,0,18"/>

                                                        <Button Content="Mods verwalten"
                                                                Click="ManageMods_Click"
                                                                Style="{StaticResource ModernButton}"
                                                                Margin="0,0,0,10"/>

                                                        <Button Content="Zurück"
                                                                Click="BackToGameList_Click"
                                                                Style="{StaticResource AccentButton}"
                                                                MinWidth="140"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="Verbindung"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,12"/>

                                            <Border Background="#10141B"
                                                    BorderBrush="#222A36"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="14"
                                                    Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Server"
                                                               Style="{StaticResource BodyText}"/>
                                                    <TextBlock x:Name="ServerStatusText"
                                                               Text="Unbekannt"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#10141B"
                                                    BorderBrush="#222A36"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="Build"
                                                               Style="{StaticResource BodyText}"/>
                                                    <TextBlock x:Name="BuildInfoText"
                                                               Text="BBs UMD • v0.0.0.0"
                                                               Foreground="{StaticResource TextMainBrush}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- MOD MANAGER VIEW -->
                            <Grid x:Name="ModManagerView" Opacity="0" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid x:Name="ModManagerInteractivePanel" Grid.RowSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock x:Name="ModManagerTitleText"
                                                       Text="Mods verwalten"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="ModManagerSubtitleText"
                                                       Text="Lade Daten..."
                                                       Foreground="{StaticResource TextSubBrush}"
                                                       FontSize="13"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button x:Name="RefreshModManagerButton"
                                                    Content="Neu laden"
                                                    Click="RefreshModManager_Click"
                                                    Style="{StaticResource ModernButton}"
                                                    Margin="0,0,10,0"/>

                                            <Button x:Name="BackFromModManagerButton"
                                                    Content="Zurück"
                                                    Click="BackFromModManager_Click"
                                                    Style="{StaticResource AccentButton}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- SERVER -->
                                        <Border Grid.Column="0" Style="{StaticResource Card}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Auf dem Server, aber nicht lokal installiert"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock x:Name="ServerModsSummaryText"
                                                           Grid.Row="1"
                                                           Foreground="{StaticResource TextSubBrush}"
                                                           FontSize="12"
                                                           Margin="0,6,0,14"/>

                                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <TextBlock x:Name="ServerModsEmptyText"
                                                                   Text="Keine Einträge."
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   Margin="0,0,0,8"
                                                                   Visibility="Collapsed"/>

                                                        <ItemsControl x:Name="ServerModsItemsControl">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#10141B"
                                                                            BorderBrush="#222A36"
                                                                            BorderThickness="1"
                                                                            CornerRadius="12"
                                                                            Padding="14"
                                                                            Margin="0,0,0,10">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding FileName}"
                                                                                           Foreground="{StaticResource TextMainBrush}"
                                                                                           FontSize="14"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding StatusText}"
                                                                                           Foreground="{StaticResource TextSubBrush}"
                                                                                           FontSize="12"
                                                                                           Margin="0,5,0,0"
                                                                                           TextWrapping="Wrap"/>
                                                                            </StackPanel>

                                                                            <Button Grid.Column="1"
                                                                                    Content="Download"
                                                                                    Tag="{Binding}"
                                                                                    Click="ServerDownload_Click"
                                                                                    Style="{StaticResource AccentButton}"
                                                                                    Width="120"
                                                                                    Margin="12,0,0,0"
                                                                                    VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <!-- LOCAL -->
                                        <Border Grid.Column="2" Style="{StaticResource Card}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Lokal installiert"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock x:Name="LocalModsSummaryText"
                                                           Grid.Row="1"
                                                           Foreground="{StaticResource TextSubBrush}"
                                                           FontSize="12"
                                                           Margin="0,6,0,14"/>

                                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <TextBlock x:Name="LocalModsEmptyText"
                                                                   Text="Keine Einträge."
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   Margin="0,0,0,8"
                                                                   Visibility="Collapsed"/>

                                                        <ItemsControl x:Name="LocalModsItemsControl">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#10141B"
                                                                            BorderBrush="#222A36"
                                                                            BorderThickness="1"
                                                                            CornerRadius="12"
                                                                            Padding="14"
                                                                            Margin="0,0,0,10">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding FileName}"
                                                                                           Foreground="{StaticResource TextMainBrush}"
                                                                                           FontSize="14"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding StatusText}"
                                                                                           Foreground="{StaticResource TextSubBrush}"
                                                                                           FontSize="12"
                                                                                           Margin="0,5,0,0"
                                                                                           TextWrapping="Wrap"/>
                                                                            </StackPanel>

                                                                            <StackPanel Grid.Column="1"
                                                                                        Orientation="Vertical"
                                                                                        VerticalAlignment="Center">
                                                                                <Button Content="Deinstallieren"
                                                                                        Tag="{Binding}"
                                                                                        Click="LocalUninstall_Click"
                                                                                        Style="{StaticResource DangerButton}"
                                                                                        Width="140"
                                                                                        Margin="10,0,0,10"/>

                                                                                <Button Content="Aktualisieren"
                                                                                        Tag="{Binding}"
                                                                                        Click="LocalUpdate_Click"
                                                                                        Style="{StaticResource AccentButton}"
                                                                                        Width="140"
                                                                                        Margin="10,0,0,0"
                                                                                        IsEnabled="{Binding CanUpdate}"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="#10141B"
                                            BorderBrush="#222A36"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="0,14,0,0">
                                        <TextBlock x:Name="ModManagerStatusText"
                                                   Text="Bereit."
                                                   Foreground="{StaticResource TextSubBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </Grid>

                                <!-- Floating action card -->
                                <Border x:Name="ModActionOverlay"
                                        Grid.Row="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Width="360"
                                        Margin="0,18,0,0"
                                        Background="#141820"
                                        BorderBrush="#2A3140"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="14"
                                        Visibility="Collapsed"
                                        Panel.ZIndex="10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24"
                                                          ShadowDepth="0"
                                                          Opacity="0.45"
                                                          Color="#000000"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <TextBlock x:Name="ModActionTitleText"
                                                   Text="Aktion läuft"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock x:Name="ModActionFileText"
                                                   Text="Datei"
                                                   Foreground="{StaticResource TextSubBrush}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>

                                        <ProgressBar x:Name="ModActionProgressBar"
                                                     Height="6"
                                                     Margin="0,10,0,8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     IsIndeterminate="True"/>

                                        <TextBlock x:Name="ModActionInfoText"
                                                   Text="Bitte warten..."
                                                   Foreground="{StaticResource TextSubBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Shared popup -->
        <Grid x:Name="PopupOverlay"
              Visibility="Collapsed"
              Opacity="0"
              Background="#99000000"
              Panel.ZIndex="999"
              MouseDown="PopupOverlay_MouseDown">

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="520"
                    MaxHeight="500"
                    Background="#141820"
                    BorderBrush="#2A3140"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      ShadowDepth="0"
                                      Opacity="0.5"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock x:Name="PopupTitleText"
                                   Text="Titel"
                                   Foreground="{StaticResource TextMainBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Border Height="1" Background="#232A37"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#10141B"
                            BorderBrush="#222A36"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="320">
                            <TextBlock x:Name="PopupMessageText"
                                       Text="Inhalt"
                                       Foreground="{StaticResource TextSubBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="PopupSecondaryButton"
                                Content="Abbrechen"
                                Click="PopupSecondaryButton_Click"
                                Style="{StaticResource ModernButton}"
                                MinWidth="130"
                                Margin="0,0,10,0"
                                Visibility="Collapsed"/>

                        <Button x:Name="PopupPrimaryButton"
                                Content="OK"
                                Click="PopupPrimaryButton_Click"
                                Style="{StaticResource AccentButton}"
                                MinWidth="130"
                                Visibility="Collapsed"/>

                        <Button x:Name="PopupCloseButton"
                                Content="Schließen"
                                Click="ClosePopup_Click"
                                Style="{StaticResource AccentButton}"
                                MinWidth="130"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>